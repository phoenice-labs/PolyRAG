data/**/*.index
data/**/*.bin
data/**/*.meta.pkl

# Runtime output files
data/profiles/
data/*.jsonl
data/*.txt
data/*.json
data/*.png
data/*.xml
data/*.csv

# Keep the .gitkeep marker so the directory structure is preserved
!data/.gitkeep


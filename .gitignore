data/**/*.pdf
data/**/*.pptx
data/**/*.ppt
data/*.pdf
data/*.pptx
data/*.ppt

# Uploaded document staging area
uploads/

# Keep the .gitkeep marker so the directory structure is preserved
!data/.gitkeep

